# OVH API Configuration
OVH_API_URL=https://api.twelvy.net
OVH_API_KEY=your_api_key_here

# ============================================================
# Up2Pay Bridge (Étape 4 — added 2026-04-18)
# ============================================================
# URL of the PHP bridge on OVH (handles MySQL writes + HMAC signing)
BRIDGE_URL=https://api.twelvy.net/bridge.php

# Auth token sent in X-Api-Key header on every bridge call.
# Must MATCH the BRIDGE_SECRET_TOKEN constant in config_secrets.php on OVH.
# Generate a fresh one with: openssl rand -hex 32
# DO NOT commit the real value — only this placeholder.
BRIDGE_API_KEY=REPLACE_WITH_64_HEX_CHARS_RANDOM_TOKEN
